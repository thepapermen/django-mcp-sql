# Root .gitignore of the extracted django-mcp-sql repository (harmless
# in-tree: covers only build artifacts under this directory).
dist/
build/
*.egg-info/
__pycache__/
*.pyc
.venv/
.venv-test/
.pytest_cache/
.ruff_cache/
example/.venv/
# Coverage artifacts (`make cov` / the CI coverage job).
.coverage
coverage.xml
htmlcov/
# Type-checking artifacts (`make typecheck` / the CI typecheck job). The
# `.mypy-pkg/` dir holds the throwaway `mcp_sql -> ..` symlink that lets
# `mypy -p mcp_sql` resolve the self-rooted package (see [tool.mypy]).
.mypy_cache/
.mypy-pkg/
# Local scratch (throwaway DBs, mypy sandboxes, ad-hoc notes).
.tmp/
